.DS_Store
.playwright-mcp

node_modules
coverage
data
venv

/.cache
/build

# Environment variables
.env
.env.*
!.env*.template
!.env*.test

# React Router
.react-router/

# Prisma generated client (owned exclusively by `prisma generate`).
app/.generated/

# tsup output for the workspace packages — built on demand, never committed.
packages/*/dist/

# Compiled server entry (emitted by `npm run build:server`, shipped in the
# published tarball but never committed).
/server.js
/server.js.map

# DuckDB-WASM extensions are downloaded by `scripts/download-duckdb-extensions.mjs`
# into `public/duckdb-extensions/` at install / build time so the runtime can
# `INSTALL httpfs` / `INSTALL spatial` from the cytario origin instead of
# `extensions.duckdb.org`. Regenerated on demand; not committed.
# Note: no trailing slash on the rule below — git cannot un-ignore files
# inside a fully-ignored directory, so we ignore the contents instead and
# white-list the SHA-256 manifest below.
/public/duckdb-extensions/*
# Exception: the SHA-256 manifest is the trust anchor for the download
# script. Tracked so version bumps are reviewed in a diff.
!/public/duckdb-extensions/checksums.json

# Playwright
/playwright-report/
/playwright-report*/
/test-results/

# LLM Support
.claude/
CLAUDE_CREDS.md

# Terraform
.terraform
terraform.tfstate
devenv/cytario-db-data/
devenv/minio-data/
devenv/postgres-data/
devenv/valkey-data/

.nvmrc
