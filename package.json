    "eslint-plugin-import": ">=2.28.1",
    "eslint-plugin-jsx-a11y": ">=6.7.1",
    "eslint-plugin-react": ">=7.33.2",
    "eslint-plugin-react-hooks": ">=4.6.0",
    "happy-dom": ">=20.0.2",
    "husky": ">=9.1.7",
    "jsdom-testing-mocks": "^1.16.0",
    "prisma": "^7.5.0",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3",
    "vite": ">=6.4.1",
