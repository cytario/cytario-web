{
  "name": "@cytario/web",
  "version": "1.0.0",
  "description": "Cytario Web — scientific imaging data browser and viewer for OME-TIFF, OME-Zarr, Parquet and GeoTIFF on S3-compatible storage.",
  "license": "AGPL-3.0",
  "sideEffects": false,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cytario/cytario-web.git"
  },
  "homepage": "https://www.cytario.com",
  "bugs": {
    "url": "https://github.com/cytario/cytario-web/issues"
  },
  "bin": {
    "cytario-web": "./bin/cytario-web.mjs"
  },
  "files": [
    "app",
    "bin",
    "bin-src",
    "build",
    "prisma",
    "public",
    "scripts",
    "vite-plugins",
    "prisma.config.ts",
    "react-router.config.ts",
    "server.js",
    "server.js.map",
    "tsconfig.json",
    "vite.config.ts",
    "!**/__tests__",
    "!**/__snapshots__",
    "!**/__mocks__",
    "!**/*.test.ts",
    "!**/*.test.tsx",
    "!**/*.spec.ts",
    "!**/*.spec.tsx",
    "!app/.generated"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "prepare": "husky || true",
    "prepack": "npm run build && npm run build:server",
    "prebuild": "node scripts/prebuild.mjs",
    "build": "node bin/cytario-web.mjs build",
    "build:server": "tsup --config tsup.server.config.ts",
    "codegen:check": "tsx scripts/codegen-check.ts",
    "dev": "node bin/cytario-web.mjs dev",
    "predev": "node scripts/prebuild.mjs && if [ -L node_modules/@cytario/design ]; then npm unlink @cytario/design --no-save 2>/dev/null && npm install @cytario/design --quiet; fi",
    "predev:design": "cd ../cytario-design && npm link --quiet && cd - > /dev/null && npm link @cytario/design --quiet && for p in react react-dom react-aria-components; do rm -rf ../cytario-design/node_modules/$p && ln -s \"$(pwd)/node_modules/$p\" ../cytario-design/node_modules/$p; done && cd ../cytario-design && npm run build:css",
    "dev:design": "concurrently -n tsup,css,storybook,web -c blue,yellow,magenta,green \"cd ../cytario-design && npx tsup --watch\" \"cd ../cytario-design && npx @tailwindcss/cli -i src/styles/tailwind.css -o dist/index.css --watch\" \"cd ../cytario-design && npm run dev\" \"node bin/cytario-web.mjs dev\"",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "prestart": "npm run build:server",
    "start": "node bin/cytario-web.mjs start",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-crypto/sha256-browser": "^5.2.0",
    "@aws-sdk/client-s3": "^3.689.0",
    "@aws-sdk/client-sts": "^3.687.0",
    "@aws-sdk/s3-request-presigner": "^3.693.0",
    "@cornerstonejs/codec-openjpeg": "^1.3.0",
    "@cytario/design": "^7.0.0",
    "@deck.gl-community/editable-layers": "^9.3.7",
    "@deck.gl-community/layers": "^9.3.7",
    "@deck.gl/core": "~9.3.4",
    "@deck.gl/extensions": "~9.3.4",
    "@deck.gl/geo-layers": "~9.3.4",
    "@deck.gl/layers": "~9.3.4",
    "@deck.gl/mesh-layers": "~9.3.4",
    "@deck.gl/react": "~9.3.4",
    "@deck.gl/widgets": "~9.3.4",
    "@duckdb/duckdb-wasm": "^1.31.1-dev31.0",
    "@duckdb/node-api": "^1.5.0-r.1",
    "@headless-tree/core": "^1.7.0",
    "@headless-tree/react": "^1.7.0",
    "@hms-dbmi/viv": "^0.22.0",
    "@hookform/resolvers": "^5.2.2",
    "@loaders.gl/core": "4.4.2",
    "@loaders.gl/wkt": "4.4.2",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-router/dev": "^7.17.0",
    "@react-router/express": "^7.17.0",
    "@react-router/node": "^7.17.0",
    "@react-router/serve": "^7.17.0",
    "@smithy/signature-v4": "^5.3.7",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@vivjs/types": "^0.22.0",
    "apache-arrow": "^21.1.0",
    "compression": "^1.8.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "filesize": "^10.1.6",
    "geotiff": "^2.0.5",
    "idb-keyval": "^6.2.2",
    "immer": "^10.1.3",
    "ioredis": "^5.10.1",
    "isbot": "^4.1.0",
    "jose": "^6.2.2",
    "lru-cache": "^11.2.7",
    "lzw-tiff-decoder": "^0.1.1",
    "morgan": "^1.10.1",
    "motion": "^12.38.0",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "rc-slider": "^11.1.9",
    "react": "^19.2.4",
    "react-aria-components": "^1.16.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-router": "^7.17.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-react-aria-components": "^2.1.0",
    "tw-animate-css": "^1.4.0",
    "vite": ">=6.4.1",
    "vite-tsconfig-paths": "^4.2.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": ">=19.8.1",
    "@commitlint/config-conventional": ">=19.8.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.0.3",
    "@semantic-release/github": "^11.0.3",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^3.2.3",
    "concurrently": "^10.0.3",
    "eslint": ">=8.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": ">=3.6.1",
    "eslint-plugin-import": ">=2.28.1",
    "eslint-plugin-jsx-a11y": ">=6.7.1",
    "eslint-plugin-react": ">=7.33.2",
    "eslint-plugin-react-hooks": ">=4.6.0",
    "happy-dom": ">=20.0.2",
    "husky": ">=9.1.7",
    "jsdom-testing-mocks": "^1.16.0",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "overrides": {
    "@hono/node-server": ">=1.19.13",
    "hono": ">=4.12.21",
    "fast-uri": ">=3.1.2",
    "fast-xml-parser": ">=5.7.0",
    "fast-xml-builder": ">=1.1.7",
    "qs": ">=6.15.2",
    "postcss": ">=8.5.10",
    "protocol-buffers-schema": ">=3.6.1",
    "wgsl_reflect": "1.2.3"
  },
  "engines": {
    "node": ">=24.10.0"
  }
}
