{
  "name": "cytario-web",
  "version": "1.0.0",
  "description": "Cytario Web",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "prepare": "husky || true",
    "build": "react-router build",
    "dev": "react-router dev",
    "predev": "if [ -L node_modules/@cytario/design ]; then npm unlink @cytario/design --no-save 2>/dev/null && npm install @cytario/design --quiet; fi",
    "predev:design": "cd ../cytario-design && npm link --quiet && cd - > /dev/null && npm link @cytario/design --quiet && for p in react react-dom; do rm -rf ../cytario-design/node_modules/$p && ln -s \"$(pwd)/node_modules/$p\" ../cytario-design/node_modules/$p; done",
    "dev:design": "concurrently -n tsup,storybook,web -c blue,magenta,green \"cd ../cytario-design && npx tsup --watch\" \"cd ../cytario-design && npm run dev\" \"react-router dev\"",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "NODE_ENV=production node server.ts",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-crypto/sha256-browser": "^5.2.0",
    "@aws-sdk/client-s3": "^3.689.0",
    "@aws-sdk/client-sts": "^3.687.0",
    "@aws-sdk/s3-request-presigner": "^3.693.0",
    "@cornerstonejs/codec-openjpeg": "^1.3.0",
    "@cytario/design": "^2.4.0",
    "@deck.gl/core": "~9.1.15",
    "@deck.gl/extensions": "~9.1.15",
    "@deck.gl/geo-layers": "~9.1.15",
    "@deck.gl/layers": "~9.1.15",
    "@deck.gl/mesh-layers": "~9.1.15",
    "@deck.gl/react": "~9.1.15",
    "@deck.gl/widgets": "~9.1.15",
    "@duckdb/duckdb-wasm": "^1.31.1-dev31.0",
    "@duckdb/node-api": "^1.5.0-r.1",
    "@hms-dbmi/viv": "^0.20.0",
    "@hookform/resolvers": "^5.2.2",
    "@loaders.gl/core": "^4.3.4",
    "@loaders.gl/wkt": "^4.3.4",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-router/express": "^7.13.2",
    "@react-router/node": "^7.13.2",
    "@react-router/serve": "^7.13.2",
    "@smithy/signature-v4": "^5.3.7",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@vivjs/loaders": "^0.20.0",
    "apache-arrow": "^21.1.0",
    "compression": "^1.8.1",
    "date-fns": "^4.1.0",
    "express": "^4.21.0",
    "filesize": "^10.1.6",
    "geotiff": "^2.0.5",
    "idb-keyval": "^6.2.2",
    "immer": "^10.1.3",
    "ioredis": "^5.10.1",
    "isbot": "^4.1.0",
    "jose": "^6.2.2",
    "lru-cache": "^11.2.7",
    "lucide-react": "^1.0.1",
    "lzw-tiff-decoder": "^0.1.1",
    "morgan": "^1.10.1",
    "motion": "^12.38.0",
    "pg": "^8.20.0",
    "rc-slider": "^11.1.9",
    "react": "^19.2.4",
    "react-aria-components": "^1.16.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-router": "^7.13.2",
    "tailwind-merge": "^3.5.0",
