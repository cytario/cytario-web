datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../app/.generated/"
  moduleFormat = "esm"
}

model ConnectionConfig {
  id         Int     @id @default(autoincrement())
  alias      String  @unique
  ownerScope String
  createdBy  String
  name       String
  provider   String  // "aws" for AWS S3, user-defined for others (e.g., "minio")
  endpoint   String  // Required - AWS endpoint or custom (MinIO)
  roleArn    String? // Optional - only needed for AWS
  region     String? // Optional - only needed for AWS
  prefix     String  @default("")

  @@map("BucketConfig")
  @@unique([ownerScope, provider, name, prefix])
  @@index([ownerScope])
}

model RecentlyViewed {
  id       Int      @id @default(autoincrement())
  userId   String
  alias    String
  pathName String
  name     String
  type     String   // "file" | "directory"
  viewedAt DateTime @default(now())

  @@unique([userId, alias, pathName])
  @@index([userId])
}

model PinnedPath {
  id           Int       @id @default(autoincrement())
  userId       String
  alias        String
  pathName     String
  displayName  String
  totalSize    BigInt?
  lastModified DateTime?

  @@unique([userId, alias, pathName])
  @@index([userId])
}
