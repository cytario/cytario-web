datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../app/.generated/"
  moduleFormat = "esm"
}

enum BucketPolicyStatus {
  none
  applied
  drifted
  error
}

model ConnectionConfig {
  id                   Int                @id @default(autoincrement())
  name                 String             @unique
  organization         String // Keycloak organization alias (tenant)
  scope                String // intra-org owner: group path or user sub
  createdBy            String
  bucketName           String
  providerConnectionId String // reference to the portal-managed / OSS-configured provider connection (carries provider type, endpoint, region)
  providerRoleId       String // reference to the portal-managed / OSS-configured provider role the connection is bound to
  prefix               String             @default("")
  bucketPolicyStatus   BucketPolicyStatus @default(none)

  recentlyViewed RecentlyViewed[] @relation("RecentlyViewedConnection")
  pinnedPaths    PinnedPath[]     @relation("PinnedPathConnection")

  @@unique([organization, providerConnectionId, bucketName, prefix])
  @@index([organization, scope])
}

model RecentlyViewed {
  id             Int      @id @default(autoincrement())
  userId         String
  connectionName String
  pathName       String
  name           String
  type           String // "file" | "directory"
  viewedAt       DateTime @default(now())

  connection ConnectionConfig @relation("RecentlyViewedConnection", fields: [connectionName], references: [name], onDelete: Cascade)

  @@unique([userId, connectionName, pathName])
  @@index([userId])
}

model PinnedPath {
  id             Int       @id @default(autoincrement())
  userId         String
  connectionName String
  pathName       String
  displayName    String
  totalSize      BigInt?
  lastModified   DateTime?

  connection ConnectionConfig @relation("PinnedPathConnection", fields: [connectionName], references: [name], onDelete: Cascade)

  @@unique([userId, connectionName, pathName])
  @@index([userId])
}
