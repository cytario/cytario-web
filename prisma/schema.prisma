datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../app/.generated/"
  moduleFormat = "esm"
}

enum BucketPolicyStatus {
  none
  applied
  drifted
  error
}

model ConnectionConfig {
  id                   String             @id @default(uuid())
  name                 String
  organization         String // Keycloak organization alias (tenant)
  createdBy            String
  bucketName           String
  providerConnectionId String // reference to the portal-managed / OSS-configured provider connection (carries provider type, endpoint, region)
  prefix               String             @default("")
  bucketPolicyStatus   BucketPolicyStatus @default(none)

  grants         ConnectionGrant[] @relation("ConnectionGrants")
  recentlyViewed RecentlyViewed[]   @relation("RecentlyViewedConnection")
  pinnedPaths    PinnedPath[]       @relation("PinnedPathConnection")

  @@index([organization, providerConnectionId, bucketName, prefix])
  @@index([organization, name])
}

model ConnectionGrant {
  id             String            @id @default(uuid())
  connectionId   String
  scope          String // intra-org group path
  providerRoleId String // reference to the portal-managed / OSS-configured provider role this grant is bound to
  connection     ConnectionConfig @relation("ConnectionGrants", fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, scope])
  @@index([scope])
}

model RecentlyViewed {
  id             String   @id @default(uuid())
  userId         String
  connectionId   String
  connectionName String
  pathName       String
  name           String
  type           String // "file" | "directory"
  viewedAt       DateTime @default(now())

  connection ConnectionConfig @relation("RecentlyViewedConnection", fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([userId, connectionId, pathName])
  @@index([userId])
}

model PinnedPath {
  id             String    @id @default(uuid())
  userId         String
  connectionId   String
  connectionName String
  pathName       String
  displayName    String
  totalSize      BigInt?
  lastModified   DateTime?

  connection ConnectionConfig @relation("PinnedPathConnection", fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([userId, connectionId, pathName])
  @@index([userId])
}
