datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../app/.generated/"
  moduleFormat = "esm"
}

model ConnectionConfig {
  id         Int     @id @default(autoincrement())
  name       String  @unique
  ownerScope String
  createdBy  String
  bucketName String
  provider   String  // "aws" for AWS S3, "minio" for MinIO
  endpoint   String  // Required - AWS endpoint or custom (MinIO)
  roleArn    String? // Optional - only needed for AWS
  region     String? // Optional - only needed for AWS
  prefix     String  @default("")

  recentlyViewed RecentlyViewed[] @relation("RecentlyViewedConnection")
  pinnedPaths    PinnedPath[]     @relation("PinnedPathConnection")

  @@unique([ownerScope, provider, bucketName, prefix])
  @@index([ownerScope])
}

model RecentlyViewed {
  id             Int      @id @default(autoincrement())
  userId         String
  connectionName String
  pathName       String
  name           String
  type           String   // "file" | "directory"
  viewedAt       DateTime @default(now())

  connection ConnectionConfig @relation("RecentlyViewedConnection", fields: [connectionName], references: [name], onDelete: Cascade)

  @@unique([userId, connectionName, pathName])
  @@index([userId])
}

model PinnedPath {
  id             Int       @id @default(autoincrement())
  userId         String
  connectionName String
  pathName       String
  displayName    String
  totalSize      BigInt?
  lastModified   DateTime?

  connection ConnectionConfig @relation("PinnedPathConnection", fields: [connectionName], references: [name], onDelete: Cascade)

  @@unique([userId, connectionName, pathName])
  @@index([userId])
}
